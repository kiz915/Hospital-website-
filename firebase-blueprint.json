{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account details",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Hospital doctor details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "department": { "type": "string" },
        "bio": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "specialty", "department", "bio", "status", "createdAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Patient hospital appointment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "patientEmail": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "doctorSpecialty": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "patientId", "patientName", "patientEmail", "doctorId", "doctorName", "doctorSpecialty", "date", "time", "status", "createdAt", "updatedAt"]
    },
    "Report": {
      "title": "Report",
      "description": "Medical report uploaded by the patient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "fileName": { "type": "string" },
        "fileSize": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["id", "patientId", "fileName", "fileSize", "uploadedAt", "category"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Record of changes performed by administrators",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adminId": { "type": "string" },
        "adminName": { "type": "string" },
        "adminEmail": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "targetId": { "type": "string" },
        "targetName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "adminId", "adminName", "adminEmail", "action", "details", "targetId", "targetName", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles details"
    },
    "doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctor entities managed by admin"
    },
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointments booked by patients"
    },
    "reports/{reportId}": {
      "schema": "Report",
      "description": "Medical reports uploaded by patients"
    },
    "audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Action logs of system updates and administration modifications"
    }
  }
}
